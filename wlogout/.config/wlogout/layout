{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Verrouiller",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Déconnexion",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Éteindre",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Redémarrer",
    "keybind" : "r"
}
